            :hasEnglishName "Atimuktaka" ;
            :hasSanskritName "atimuktaka" ;
            rdfs:comment "Planting by roots/branches" ;
            rdfs:label "Atimuktaka" .


###  http://www.iish.org/ontology/vrukshaayurveda#AvataPreparation
:AvataPreparation rdf:type owl:NamedIndividual ,
