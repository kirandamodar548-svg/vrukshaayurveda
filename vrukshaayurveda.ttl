@prefix : <urn:absolute:h/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <urn:absolute:h/> .

<http://www.iish.org/ontology/vrukshaayurveda> rdf:type owl:Ontology ;
                                                owl:versionIRI <http://www.iish.org/ontology/vrukshaayurveda/1.0> .

#################################################################
#    Object Properties
#################################################################

###  http://www.iish.org/ontology/vrukshaayurveda#auspiciousUnder
:auspiciousUnder rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty ;
                 rdfs:domain :PlantingPractice ;
                 rdfs:range :Nakshatra ;
                 rdfs:comment "This planting practice is auspicious when performed under this nakshatra" .


###  http://www.iish.org/ontology/vrukshaayurveda#growsIn
:growsIn rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain :Plant ;
         rdfs:range :Soil .


###  http://www.iish.org/ontology/vrukshaayurveda#hasDisease
:hasDisease rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf owl:topObjectProperty ;
            rdfs:domain :Plant ;
            rdfs:range :Disease ;
            rdfs:comment "This plant suffers from the following disease" .


###  http://www.iish.org/ontology/vrukshaayurveda#hasModernScientificNote
:hasModernScientificNote rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf owl:topObjectProperty ;
                         rdfs:domain :VrukshaayurvedaEntity ;
                         rdfs:range :ModernScientificNote ;
                         rdfs:comment "This ancient concept has the following modern scientific explanation" .


###  http://www.iish.org/ontology/vrukshaayurveda#hasSymptom
:hasSymptom rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf owl:topObjectProperty ;
            rdfs:domain :Disease ;
            rdfs:range :Symptom ;
            rdfs:comment "This disease shows the following visible symptom" .


###  http://www.iish.org/ontology/vrukshaayurveda#irrigatedInSeason
:irrigatedInSeason rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf owl:topObjectProperty ;
                   rdfs:domain :PlantingPractice ;
                   rdfs:range :Season ;
                   rdfs:comment "Irrigation schedule to be followed in this season" .


###  http://www.iish.org/ontology/vrukshaayurveda#occursIn
:occursIn rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf owl:topObjectProperty ;
          rdfs:range :Tree ;
          rdfs:comment "This symptom occurs in this plant/tree" .


###  http://www.iish.org/ontology/vrukshaayurveda#performedWithRitual
:performedWithRitual rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf owl:topObjectProperty ;
                     rdfs:domain :PlantingPractice ;
                     rdfs:range :Ritual ;
                     rdfs:comment "This planting practice must be performed along with this ritual" .


###  http://www.iish.org/ontology/vrukshaayurveda#plantedInSeason
:plantedInSeason rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty ;
                 rdfs:domain :Plant ;
                 rdfs:range :Season ;
                 rdfs:comment "Planting or grafting of this plant should be done in this season" .


###  http://www.iish.org/ontology/vrukshaayurveda#recommendedFor
:recommendedFor rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf owl:topObjectProperty ;
                rdfs:domain :Plant ;
                rdfs:range :Location ;
                rdfs:comment "This plant is specially recommended for this location" .


###  http://www.iish.org/ontology/vrukshaayurveda#suitableForLocation
:suitableForLocation rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf owl:topObjectProperty ;
                     rdfs:domain :Plant ;
                     rdfs:range :Location ;
                     rdfs:comment "This plant is recommended for planting in this specific location (park, lake bank, wetland)" .


###  http://www.iish.org/ontology/vrukshaayurveda#treatedBy
:treatedBy rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdfs:domain :Disease ;
           rdfs:range :Material ;
           rdfs:comment "The disease is cured by this treatment technique" .


###  http://www.iish.org/ontology/vrukshaayurveda#usesMaterial
:usesMaterial rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain :TreatmentTechnique ;
              rdfs:range :Material ;
              rdfs:comment "This treatment technique requires or uses this material" .


###  http://www.iish.org/ontology/vrukshaayurveda#usesSubMaterial
:usesSubMaterial rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty ;
                 rdfs:domain :Material ;
                 rdfs:range :Material ;
                 rdfs:comment "This material is prepared using or contains these sub-materials" .


#################################################################
#    Data properties
#################################################################

###  http://www.iish.org/ontology/vrukshaayurveda#hasBookPageReference
:hasBookPageReference rdf:type owl:DatatypeProperty ;
                      rdfs:subPropertyOf owl:topDataProperty ;
                      rdfs:domain :VrukshaayurvedaEntity ;
                      rdfs:range xsd:string ;
                      rdfs:comment "DEPRECATED Page number in Dr. N. Gopalakrishnan’s Vrukshaayurveda book" ;
                      owl:deprecated "true"^^xsd:boolean .


###  http://www.iish.org/ontology/vrukshaayurveda#hasEnglishName
:hasEnglishName rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf owl:topDataProperty ;
                rdfs:domain :VrukshaayurvedaEntity ;
                rdfs:range xsd:string ;
                rdfs:comment "Common English or botanical name" .


###  http://www.iish.org/ontology/vrukshaayurveda#hasModernExplanation
:hasModernExplanation rdf:type owl:DatatypeProperty ;
                      rdfs:subPropertyOf owl:topDataProperty ;
                      rdfs:domain :VrukshaayurvedaEntity ;
                      rdfs:range xsd:string ;
                      rdfs:comment "Short modern scientific explanation or parallel" .


###  http://www.iish.org/ontology/vrukshaayurveda#hasSanskritName
:hasSanskritName rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf owl:topDataProperty ;
                 rdfs:domain :VrukshaayurvedaEntity ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Original Sanskrit name of the entity as given in the book" .


###  http://www.iish.org/ontology/vrukshaayurveda#hasVerseReference
:hasVerseReference rdf:type owl:DatatypeProperty ;
                   rdfs:subPropertyOf owl:topDataProperty ;
                   rdfs:domain :VrukshaayurvedaEntity ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Corresponding Sanskrit verse number from Bṛhat Saṃhitā Chapter 55" .


#################################################################
#    Classes
#################################################################

###  http://www.iish.org/ontology/vrukshaayurveda#AnimalProduct
:AnimalProduct rdf:type owl:Class ;
               rdfs:subClassOf :Material ;
               rdfs:comment "Animal-derived products including Gomaya (cow dung), Kṣīra (milk), Ghṛta (ghee) and meat/fish" .


###  http://www.iish.org/ontology/vrukshaayurveda#Creeper
:Creeper rdf:type owl:Class ;
         rdfs:subClassOf :Plant ;
         rdfs:comment "Climbing plants suitable for initial planting in parks and dwellings (e.g. Priyaṅgu)" .


###  http://www.iish.org/ontology/vrukshaayurveda#Disease
:Disease rdf:type owl:Class ;
         rdfs:subClassOf :VrukshaayurvedaEntity ;
         rdfs:comment "Plant diseases caused by climatic factors, overcrowding, shade or animal disturbance" .


###  http://www.iish.org/ontology/vrukshaayurveda#FermentedMixture
:FermentedMixture rdf:type owl:Class ;
                  rdfs:subClassOf :Material ;
                  rdfs:comment "Special 7-night fermented broths made with dung, grains, meat and fish for continuous flowering and fruiting" .


###  http://www.iish.org/ontology/vrukshaayurveda#Grain
:Grain rdf:type owl:Class ;
       rdfs:subClassOf :Material ;
       rdfs:comment "Pulses and grains such as Til (sesame), Māṣa (black gram), Mudga (green gram) and Yava (barley) used for soil and seed treatment" .


###  http://www.iish.org/ontology/vrukshaayurveda#Location
:Location rdf:type owl:Class ;
          rdfs:subClassOf :VrukshaayurvedaEntity ;
          rdfs:comment "Suitable geographical locations for planting such as lake/reservoir banks (jala-prānta), parks (ārāma) and low-lying wet lands (anūpa)" .


###  http://www.iish.org/ontology/vrukshaayurveda#Material
:Material rdf:type owl:Class ;
          rdfs:subClassOf :VrukshaayurvedaEntity ;
          rdfs:comment "All natural substances and ingredients used in planting, treatment, soil improvement and seed enhancement" .


###  http://www.iish.org/ontology/vrukshaayurveda#ModernScientificNote
:ModernScientificNote rdf:type owl:Class ;
                      rdfs:subClassOf :VrukshaayurvedaEntity ;
                      rdfs:comment "Contemporary scientific explanations and parallels (e.g. beneficial microbes in cow dung, organic nitrogen sources, grafting physiology, bio-amendments) for the ancient practices" .


###  http://www.iish.org/ontology/vrukshaayurveda#Nakshatra
:Nakshatra rdf:type owl:Class ;
           rdfs:subClassOf :VrukshaayurvedaEntity ;
           rdfs:comment "Auspicious lunar mansions (Dhruva group, Mṛdu group, Mūla, Viśākhā, Puṣya, Śravaṇa, Aśvinī, Hasta etc.) recommended for planting and sowing" .


###  http://www.iish.org/ontology/vrukshaayurveda#Plant
:Plant rdf:type owl:Class ;
       rdfs:subClassOf :VrukshaayurvedaEntity ;
       rdfs:comment "All living plants, trees, creepers and shrubs discussed in Vrukshaayurveda for aesthetic beauty, medicinal value and economic utility" .


###  http://www.iish.org/ontology/vrukshaayurveda#PlantMaterial
:PlantMaterial rdf:type owl:Class ;
               rdfs:subClassOf :Material ;
               rdfs:comment "Herbal and plant-based materials such as Vidanga, Aṅgola, Uśīra and Haridrā" .


###  http://www.iish.org/ontology/vrukshaayurveda#PlantingPractice
:PlantingPractice rdf:type owl:Class ;
                  rdfs:subClassOf :VrukshaayurvedaEntity ;
                  rdfs:comment "Rules for spacing (12–20 hastas), directional planting, seasonal irrigation and grafting techniques" .


###  http://www.iish.org/ontology/vrukshaayurveda#Ritual
:Ritual rdf:type owl:Class ;
        rdfs:subClassOf :VrukshaayurvedaEntity ;
        rdfs:comment "Pre-planting purification and worship practices including bathing, tree worship and application of medicated pastes" .


###  http://www.iish.org/ontology/vrukshaayurveda#Season
:Season rdf:type owl:Class ;
        rdfs:subClassOf :VrukshaayurvedaEntity ;
        rdfs:comment "Six seasons (ṛtu) and their specific influence on planting, grafting and irrigation schedules" .


###  http://www.iish.org/ontology/vrukshaayurveda#Shrub
:Shrub rdf:type owl:Class ;
       rdfs:subClassOf :Plant ;
       rdfs:comment "Bushy plants included in the Vrukshaayurveda classification" .


###  http://www.iish.org/ontology/vrukshaayurveda#Soil
:Soil rdf:type owl:Class ;
      rdfs:subClassOf :VrukshaayurvedaEntity ;
      rdfs:comment "A plant grows in this type of soil after proper preparation" ,
                   "Types of soil and ancient bio-amendment techniques for making hard laterite soil soft and fertile" .


###  http://www.iish.org/ontology/vrukshaayurveda#Symptom
:Symptom rdf:type owl:Class ;
         rdfs:subClassOf :VrukshaayurvedaEntity ;
         rdfs:comment "Visible signs of plant disorders such as pale leaves (pāṇḍupatratā), wilting, absence of shoots, branch drying and bleeding sores" .


###  http://www.iish.org/ontology/vrukshaayurveda#TreatmentTechnique
:TreatmentTechnique rdf:type owl:Class ;
                    rdfs:subClassOf :VrukshaayurvedaEntity ;
                    rdfs:comment "All ancient methods of propagation, disease management, soil preparation, grafting, seed treatment and rejuvenation described in the text" .


###  http://www.iish.org/ontology/vrukshaayurveda#Tree
:Tree rdf:type owl:Class ;
      rdfs:subClassOf :Plant ;
      rdfs:comment "Woody perennial plants recommended for parks, gardens, wetlands and fruit production" .


###  http://www.iish.org/ontology/vrukshaayurveda#VrukshaayurvedaEntity
:VrukshaayurvedaEntity rdf:type owl:Class ;
                       rdfs:comment "Root class containing all concepts from the 55th chapter (Vrukshaayurveda) of Varahamihira’s Bṛhat Saṃhitā (505 AD) with modern scientific annotations" .


#################################################################
#    Individuals
#################################################################

###  http://www.iish.org/ontology/vrukshaayurveda#Angola
:Angola rdf:type owl:NamedIndividual ,
                 :PlantMaterial ;
        :hasEnglishName "Alangium" ;
        :hasSanskritName "angola" ;
        rdfs:comment "Juice for 100× seed treatment" ;
        rdfs:label "Angola" .


###  http://www.iish.org/ontology/vrukshaayurveda#Anupa
:Anupa rdf:type owl:NamedIndividual ,
                :Location ;
       :plantedInSeason :Varsha ;
       :suitableForLocation :Arjuna ,
                            :Jambu ,
                            :Kadamba ,
                            :Udumbara ;
       :hasEnglishName "Wetland" ;
       :hasSanskritName "Anupa" ;
       rdfs:comment "Low-lying wet lands for specific trees" ;
       rdfs:label "Wetland" .


###  http://www.iish.org/ontology/vrukshaayurveda#Apravala
:Apravala rdf:type owl:NamedIndividual ,
                   :Disease ;
          :hasSymptom :NoShoots ;
          :occursIn :Panasa ;
          :treatedBy :Kshira ,
                     :Vidanga ;
          :hasEnglishName "No New Shoots" ;
          :hasSanskritName "Apravala" ;
          rdfs:comment "Absence or sparsity of new shoots" ;
          rdfs:label "No New Shoots" .


