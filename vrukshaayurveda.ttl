       :auspiciousUnder :Dadima ,
                        :NakshatraTiming ,
                        :SaptaRatroshita ;
       :hasEnglishName "Hasta" ;
       :hasSanskritName "Hasta" ;
       rdfs:comment "Auspicious for planting" ;
       rdfs:label "Hasta" .


